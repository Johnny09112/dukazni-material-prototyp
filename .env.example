# Zkopíruj do .env a doplň. Bez klíče hra běží na fallback šablonách.
# Poskytovatel LLM je zatím nerozhodnut (ADR-004) - proměnné jsou generické.
VITE_LLM_PROVIDER=fallback
VITE_LLM_API_KEY=

# Dev override: cesta k lokálnímu checkoutu design repa (živé ladění obsahu).
# Nenastaveno = čte se pinovaný submodule content/.
# CONTENT_DIR=C:\Projekty\Case files
